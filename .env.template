# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7
LOG_LEVEL=INFO

# OPTIONAL — when set, every /api/cases, /api/case/.../source/,
# /api/export_pdf, and /api/run/{case_id} request must present this
# value either as the X-API-Key header or as ?api_key= query param.
# Without it, those endpoints are open (a startup warning is logged).
# REQUIRED for any non-loopback deployment. Generate via e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# APPEAL_API_KEY=

# OPTIONAL — Next.js client-side bundle reads this so browser fetches
# can attach the key. NEXT_PUBLIC_* vars are visible to anyone who
# loads the page, so for real production hide the key behind a
# server-side proxy instead.
# NEXT_PUBLIC_APPEAL_API_KEY=

# OPTIONAL — per-IP rate limits. Sliding windows. Defaults are
# reasonable for the demo; tighten in production based on telemetry.
# Two independent buckets: /api/run (each call is ~$1) and
# /api/export_pdf (CPU-only, intentionally looser).
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_MAX_STARTS=5
# PDF_RATE_LIMIT_WINDOW_SECONDS=60
# PDF_RATE_LIMIT_MAX=20

# OPTIONAL — max request body size (bytes). 413 is returned for any
# request whose body exceeds this. Default 2 MiB — well above a max-
# shape AppealDraft (~1 MiB). Raise only if you genuinely need bigger
# request bodies; lower values are always safer.
# MAX_REQUEST_BODY_BYTES=2097152
