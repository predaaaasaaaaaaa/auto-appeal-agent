# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7
LOG_LEVEL=INFO

# OPTIONAL — when set, every /api/cases, /api/case/.../source/,
# /api/export_pdf, and /api/run/{case_id} request must present this
# value either as the X-API-Key header or as ?api_key= query param.
# Without it, those endpoints are open (a startup warning is logged).
# REQUIRED for any non-loopback deployment. Generate via e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# APPEAL_API_KEY=

# OPTIONAL — Next.js client-side bundle reads this so browser fetches
# can attach the key. NEXT_PUBLIC_* vars are visible to anyone who
# loads the page, so for real production hide the key behind a
# server-side proxy instead.
# NEXT_PUBLIC_APPEAL_API_KEY=
